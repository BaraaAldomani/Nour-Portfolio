# Filament publishes its compiled assets into public/; they are rebuilt on deploy
# by `artisan filament:assets` and must never be committed.
/public/css/filament
/public/js/filament
/public/fonts/filament

# Every .env is ignored except the example and the committed encrypted ones.
.env*
!.env.example
!.env.*.encrypted
